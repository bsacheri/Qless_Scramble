<svg xmlns="http://www.w3.org/2000/svg" width="512" height="512" viewBox="0 0 512 512">
  <defs>
    <style>
      :root { --fg:#414; --bg:#5FA; }
      .bg { fill: var(--bg); }
      .tile {
        fill: var(--bg);           /* blank tile (same as background) */
        stroke: var(--fg);
        stroke-width: 10;
        stroke-linejoin: round;
      }
    </style>

    <filter id="shadow" x="-25%" y="-25%" width="170%" height="170%">
      <feDropShadow dx="0" dy="10" stdDeviation="10" flood-color="#414" flood-opacity="0.25"/>
    </filter>
  </defs>

  <rect class="bg" x="0" y="0" width="512" height="512"/>

  <!-- Centered cluster -->
  <!-- tile=72 gap=12 pitch=84; cluster bounds are 576x576, centered => translate(-32,-32) -->
  <g filter="url(#shadow)" transform="translate(-32,-32)">
    <!-- helper: x = col*84, y = row*84 -->

    <!-- Main horizontal word: row 3, cols 0..6 -->
    <rect class="tile" x="0"   y="252" width="72" height="72" rx="18" ry="18"/>
    <rect class="tile" x="84"  y="252" width="72" height="72" rx="18" ry="18"/>
    <rect class="tile" x="168" y="252" width="72" height="72" rx="18" ry="18"/>
    <rect class="tile" x="252" y="252" width="72" height="72" rx="18" ry="18"/>
    <rect class="tile" x="336" y="252" width="72" height="72" rx="18" ry="18"/>
    <rect class="tile" x="420" y="252" width="72" height="72" rx="18" ry="18"/>
    <rect class="tile" x="504" y="252" width="72" height="72" rx="18" ry="18"/>

    <!-- Main vertical word: col 3, rows 0..6 (intersects at center tile col3,row3) -->
    <rect class="tile" x="252" y="0"   width="72" height="72" rx="18" ry="18"/>
    <rect class="tile" x="252" y="84"  width="72" height="72" rx="18" ry="18"/>
    <rect class="tile" x="252" y="168" width="72" height="72" rx="18" ry="18"/>
    <!-- center (252,252) already drawn above -->
    <rect class="tile" x="252" y="336" width="72" height="72" rx="18" ry="18"/>
    <rect class="tile" x="252" y="420" width="72" height="72" rx="18" ry="18"/>
    <rect class="tile" x="252" y="504" width="72" height="72" rx="18" ry="18"/>

    <!-- Third word cluster (upper-left of center): an L that intersects at (2,2) -->
    <rect class="tile" x="168" y="168" width="72" height="72" rx="18" ry="18"/>
    <rect class="tile" x="84"  y="168" width="72" height="72" rx="18" ry="18"/>
    <rect class="tile" x="84"  y="84"  width="72" height="72" rx="18" ry="18"/>

    <!-- Fourth word cluster (lower-right of center): an L that intersects at (4,4) -->
    <rect class="tile" x="336" y="336" width="72" height="72" rx="18" ry="18"/>
    <rect class="tile" x="420" y="336" width="72" height="72" rx="18" ry="18"/>
    <rect class="tile" x="420" y="420" width="72" height="72" rx="18" ry="18"/>
  </g>
</svg>