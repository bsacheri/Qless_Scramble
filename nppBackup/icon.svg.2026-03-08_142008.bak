<svg xmlns="http://www.w3.org/2000/svg" width="512" height="512" viewBox="0 0 512 512">
  <defs>
    <style>
      :root { --fg:#414; --bg:#5FA; }
      .bg { fill: var(--bg); }
      .tile {
        fill: var(--bg);          /* blank tile */
        stroke: var(--fg);
        stroke-width: 10;
        stroke-linejoin: round;
      }
    </style>

    <filter id="shadow" x="-25%" y="-25%" width="170%" height="170%">
      <feDropShadow dx="0" dy="10" stdDeviation="10" flood-color="#414" flood-opacity="0.25"/>
    </filter>
  </defs>

  <rect class="bg" x="0" y="0" width="512" height="512"/>

  <!-- 12-tile centered cluster -->
  <!-- tile=72 gap=12 pitch=84 -->
  <!-- cluster bounds: cols 0..4 (w=408), rows 0..3 (h=324) -->
  <!-- centered translate: ((512-408)/2=52, (512-324)/2=94) -->
  <g filter="url(#shadow)" transform="translate(52,94)">
    <!-- helper: x = col*84, y = row*84 -->

    <!-- Horizontal word length 5: row 1, cols 0..4 (5 tiles) -->
    <rect class="tile" x="0"   y="84" width="72" height="72" rx="18" ry="18"/>
    <rect class="tile" x="84"  y="84" width="72" height="72" rx="18" ry="18"/>
    <rect class="tile" x="168" y="84" width="72" height="72" rx="18" ry="18"/>
    <rect class="tile" x="252" y="84" width="72" height="72" rx="18" ry="18"/>
    <rect class="tile" x="336" y="84" width="72" height="72" rx="18" ry="18"/>

    <!-- Vertical word length 4 crossing at col 2,row1: col 2, rows 0..3 (adds 3 tiles) -->
    <rect class="tile" x="168" y="0"   width="72" height="72" rx="18" ry="18"/>
    <!-- (168,84) is intersection already drawn -->
    <rect class="tile" x="168" y="168" width="72" height="72" rx="18" ry="18"/>
    <rect class="tile" x="168" y="252" width="72" height="72" rx="18" ry="18"/>

    <!-- Second vertical word length 3 crossing at col 4,row1: col 4, rows 1..3 (adds 2 tiles) -->
    <!-- (336,84) is intersection already drawn -->
    <rect class="tile" x="336" y="168" width="72" height="72" rx="18" ry="18"/>
    <rect class="tile" x="336" y
