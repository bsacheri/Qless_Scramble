<svg xmlns="http://www.w3.org/2000/svg" width="512" height="512" viewBox="0 0 512 512">
  <defs>
    <style>
      :root {
        --fg: #414;
        --bg: #5FA;
      }
      .bg { fill: var(--bg); }

      /* Tile look: same fill as bg to appear "blank", but outlined in forecolor */
      .tile {
        fill: var(--bg);
        stroke: var(--fg);
        stroke-width: 10;
        stroke-linejoin: round;
      }

      /* Subtle shadow using forecolor (keeps the 2-color constraint) */
      .shadow {
        filter: url(#shadow);
      }
    </style>

    <filter id="shadow" x="-20%" y="-20%" width="160%" height="160%">
      <feDropShadow dx="0" dy="10" stdDeviation="10" flood-color="#414" flood-opacity="0.25"/>
    </filter>
  </defs>

  <!-- Background -->
  <rect class="bg" x="0" y="0" width="512" height="512"/>

  <!-- Tile cluster (centered with generous padding for phone shortcut) -->
  <!-- Tile size: 72, gap: 12. Grid pitch = 84 -->
  <g class="shadow" transform="translate(58,58)">
    <!-- convenience: x = col*84, y = row*84 -->
    <!-- Main horizontal word (row 4, cols 1..7) -->
    <rect class="tile" x="84"  y="336" width="72" height="72" rx="18" ry="18"/>
    <rect class="tile" x="168" y="336" width="72" height="72" rx="18" ry="18"/>
    <rect class="tile" x="252" y="336" width="72" height="72" rx="18" ry="18"/>
    <rect class="tile" x="336" y="336" width="72" height="72" rx="18" ry="18"/>
    <rect class="tile" x="420" y="336" width="72" height="72" rx="18" ry="18"/>
    <rect class="tile" x="504" y="336" width="72" height="72" rx="18" ry="18"/>
    <rect class="tile" x="588" y="336" width="72" height="72" rx="18" ry="18"/>

    <!-- Main vertical word (col 4, rows 1..7), intersects at center tile (col4,row4) -->
    <rect class="tile" x="336" y="84"  width="72" height="72" rx="18" ry="18"/>
    <rect class="tile" x="336" y="168" width="72" height="72" rx="18" ry="18"/>
    <rect class="tile" x="336" y="252" width="72" height="72" rx="18" ry="18"/>
    <!-- intersection tile (already drawn above at x=336,y=336) -->
    <rect class="tile" x="336" y="420" width="72" height="72" rx="18" ry="18"/>
    <rect class="tile" x="336" y="504" width="72" height="72" rx="18" ry="18"/>
    <rect class="tile" x="336" y="588" width="72" height="72" rx="18" ry="18"/>

    <!-- Third "word" cluster: a short cross near upper-left of the center -->
    <rect class="tile" x="252" y="252" width="72" height="72" rx="18" ry="18"/>
    <rect class="tile" x="168" y="252" width="72" height="72" rx="18" ry="18"/>
    <rect class="tile" x="168" y="168" width="72" height="72" rx="18" ry="18"/>

    <!-- Fourth "word" cluster: short cross near lower-right of the center -->
    <rect class="tile" x="420" y="420" width="72" height="72" rx="18" ry="18"/>
    <rect class="tile" x="504" y="420" width="72" height="72" rx="18" ry="18"/>
    <rect class="tile" x="504" y="504" width="72" height="72" rx="18" ry="18"/>
  </g>
</svg>